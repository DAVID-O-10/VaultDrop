# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Email (configure one of these)
# Option 1: SMTP/Nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=VaultDrop <your@gmail.com>

# Option 2: SendGrid
# SENDGRID_API_KEY=your-sendgrid-key

# Option 3: Resend
# RESEND_API_KEY=your-resend-key

# Storage (local for dev, swap for S3/R2 in prod)
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# AWS S3 (optional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=vaultdrop-transfers

# Cloudflare R2 (optional)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=vaultdrop-transfers

# Security
ENCRYPTION_SECRET=change-this-to-a-random-64-char-secret-key-in-production
